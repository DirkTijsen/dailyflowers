SUPABASE_PROJECT_ID="daily_flowers_prod"
SUPABASE_URL="https://your-api-host.example.com"
SUPABASE_PUBLISHABLE_KEY="change-me"
SUPABASE_SERVICE_ROLE_KEY="change-me"

VITE_SUPABASE_PROJECT_ID="daily_flowers_prod"
VITE_SUPABASE_URL="https://your-api-host.example.com"
VITE_SUPABASE_PUBLISHABLE_KEY="change-me"

LOCAL_DATABASE_URL="postgres://user:password@host:5432/database"
LOCAL_POSTGRES_URL="postgres://user:password@host:5432/postgres"
LOCAL_JWT_SECRET="replace-with-a-long-random-secret"
LOCAL_TOKEN_TTL_SECONDS="604800"
LOCAL_ADMIN_EMAIL="admin@example.com"
LOCAL_ADMIN_PASSWORD="replace-with-a-strong-password"

SHOPIFY_API_VERSION="2026-04"
SHOPIFY_SYNC_DAYS="60"
SHOPIFY_WEBHOOK_SECRET="replace-me"

MOLLIE_API_KEY="replace-me"
MOLLIE_SYNC_FROM="2026-01-01T00:00:00Z"
MOLLIE_INCREMENTAL_OVERLAP_HOURS="72"
MOLLIE_INITIAL_LOOKBACK_DAYS="7"
MOLLIE_FETCH_TIMEOUT_MS="30000"
